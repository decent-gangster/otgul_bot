# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Токен бота, полученный от @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# ── Администраторы ────────────────────────────────────────────────────────────
# Telegram ID администраторов через запятую (без пробелов)
# Узнать свой ID можно у @userinfobot
ADMIN_IDS=123456789,987654321

# ── Группа команды ────────────────────────────────────────────────────────────
# ID общей группы/канала, куда бот будет писать дайджест и уведомления об отсутствии.
# Для групп ID всегда отрицательное число (начинается с -100...).
# Чтобы узнать ID: добавьте @userinfobot в группу и напишите /start.
GROUP_ID=-1001234567890
